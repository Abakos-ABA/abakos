new file mode 100644
index 0000000..f40051a
--- /dev/null
+++ b/wire/abakos.go
@@ -0,0 +1,29 @@
+// Copyright (c) 2026 The Abakos developers
+// Use of this source code is governed by an ISC license.
+
+package wire
+
+// Abakos PoUW wire extensions (see docs/spec-pouw-integration.md in abakos repo).
+const (
+	// BlockVersionAbakos marks headers that use ProofCommitment + certificate
+	// instead of Bitcoin SHA-256 nonce grinding.
+	BlockVersionAbakos = 0x20000000
+
+	// AbakosHeaderPayloadSize is the fixed Abakos header (no nonce field).
+	AbakosHeaderPayloadSize = 110
+
+	// MaxAbakosCertificateSize caps PoUW certificate bytes on the wire (T0).
+	MaxAbakosCertificateSize = 65536
+)
+
+// IsAbakosVersion reports whether v uses Abakos PoUW header encoding.
+func IsAbakosVersion(version int32) bool {
+	return version&BlockVersionAbakos != 0
+}
+
+func blockHeaderSerializedLen(version int32) int {
+	if IsAbakosVersion(version) {
+		return AbakosHeaderPayloadSize
+	}
+	return blockHeaderLen
+}
