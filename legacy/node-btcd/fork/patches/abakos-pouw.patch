+// Copyright (c) 2026 The Abakos developers
+// Use of this source code is governed by an ISC license.
+
+package blockchain
+
+import (
+	"fmt"
+	"math/big"
+	"sync"
+
+	"github.com/btcsuite/btcd/btcutil"
+	"github.com/btcsuite/btcd/wire"
+)
+
+// PoUWVerifier validates an Abakos block header and certificate.
+// Registered from github.com/rexmarlon/abakos/node/fork at init time.
+type PoUWVerifier interface {
+	Verify(header *wire.BlockHeader, certificate []byte) error
+}
+
+var (
+	pouwVerifierMu sync.RWMutex
+	pouwVerifier   PoUWVerifier
+)
+
+// RegisterPoUWVerifier installs the Abakos PoUW verifier (call once at node startup).
+func RegisterPoUWVerifier(v PoUWVerifier) {
+	pouwVerifierMu.Lock()
+	pouwVerifier = v
+	pouwVerifierMu.Unlock()
+}
+
+func getPoUWVerifier() PoUWVerifier {
+	pouwVerifierMu.RLock()
+	defer pouwVerifierMu.RUnlock()
+	return pouwVerifier
+}
+
+func checkAbakosPowTarget(header *wire.BlockHeader, powLimit *big.Int) error {
+	target := CompactToBig(header.Bits)
+	if target.Sign() <= 0 {
+		str := fmt.Sprintf("block target difficulty of %064x is too low", target)
+		return ruleError(ErrUnexpectedDifficulty, str)
+	}
+	if target.Cmp(powLimit) > 0 {
+		str := fmt.Sprintf("block target difficulty of %064x is "+
+			"higher than max of %064x", target, powLimit)
+		return ruleError(ErrUnexpectedDifficulty, str)
+	}
+	return nil
+}
+
+func checkProofOfUsefulWork(header *wire.BlockHeader, certificate []byte,
+	powLimit *big.Int, flags BehaviorFlags) error {
+
+	if err := checkAbakosPowTarget(header, powLimit); err != nil {
+		return err
+	}
+	if flags&BFNoPoWCheck == BFNoPoWCheck {
+		return nil
+	}
+	if len(certificate) == 0 {
+		return ruleError(ErrCertificateMissing, "certificate is missing")
+	}
+	v := getPoUWVerifier()
+	if v == nil {
+		return ruleError(ErrHighHash, "PoUW verifier not registered")
+	}
+	if err := v.Verify(header, certificate); err != nil {
+		return ruleError(ErrHighHash, err.Error())
+	}
+	return nil
+}
+
+// CheckProofOfUsefulWork validates an Abakos block's PoUW certificate.
+func CheckProofOfUsefulWork(block *btcutil.Block, powLimit *big.Int) error {
+	msg := block.MsgBlock()
+	if !wire.IsAbakosVersion(msg.Header.Version) {
+		return ruleError(ErrHighHash, "not an Abakos block version")
+	}
+	return checkProofOfUsefulWork(&msg.Header, msg.Certificate, powLimit, BFNone)
+}
